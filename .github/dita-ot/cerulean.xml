<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="https://www.dita-ot.org/rng/project.rnc" type="application/relax-ng-compact-syntax"?>
<project xmlns="https://www.dita-ot.org/project">
  <context id="pdf" name="PDF">
    <input href="../../sample/document.ditamap"/>
    <profile>
      <ditaval href="pdf.ditaval"/>
    </profile>
  </context>
  <deliverable name="PDF" id="pdf">
    <context idref="pdf"/>
    <output href="pdf"/>
    <publication transtype="pdf-bootstrap">
      <param name="args.rellinks" value="none"/>
      <param name="processing-mode" value="strict"/>
      <param name="bootstrap.theme" value="cerulean"/>
      <param name="outputFile.base" value="cerulean"/>
    </publication>
  </deliverable>
</project>
